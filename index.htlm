<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AS98 — Planificador Cyber 2026</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Segoe UI', Arial, sans-serif; background: #eef0f3; font-size: 12px; color: #1a1a1a; }

/* ── Summary Bar ── */
#bar {
  position: sticky; top: 0; z-index: 300;
  background: #0d1b2a; color: #fff;
  padding: 0 18px;
  display: flex; flex-direction: column;
  box-shadow: 0 3px 10px rgba(0,0,0,.4);
}
#bar-top {
  display: flex; align-items: center; gap: 0; flex-wrap: nowrap;
  padding: 7px 0 4px;
  border-bottom: 1px solid #1e3047;
}
#bar-bot {
  display: flex; align-items: center; gap: 0;
  padding: 4px 0 6px;
}
.brand { font-size: 14px; font-weight: 800; color: #ffd700; letter-spacing: 1px; margin-right: 16px; white-space: nowrap; }
.sep   { width: 1px; height: 28px; background: #2e4057; margin: 0 12px; flex-shrink: 0; }
.kpi   { display: flex; flex-direction: column; align-items: center; min-width: 72px; }
.kpi .lbl { font-size: 8.5px; text-transform: uppercase; color: #8899aa; letter-spacing: .4px; white-space: nowrap; }
.kpi .val { font-size: 15px; font-weight: 700; line-height: 1.2; white-space: nowrap; }
.val.green  { color: #4caf50; }
.val.blue   { color: #64b5f6; }
.val.yellow { color: #ffd700; }
.val.orange { color: #ff9800; }
.val.red    { color: #ef5350; }
.val.white  { color: #fff; }
.val.gray   { color: #888; }
.val.teal   { color: #4dd0e1; }
.val.lime   { color: #aed581; }

/* tier mini-breakdown in bar */
.tier-pill {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 2px 10px 2px 8px; border-radius: 12px;
  font-size: 10px; font-weight: 700; margin-right: 6px;
  border: 1px solid transparent;
}
.tp-sd  { background: #1a237e; border-color: #5c6bc0; color: #c5cae9; }
.tp-40  { background: #880e4f; border-color: #f06292; color: #fce4ec; }
.tp-30  { background: #b71c1c; border-color: #ef5350; color: #ffcdd2; }
.tp-20  { background: #bf360c; border-color: #ff7043; color: #ffe0b2; }
.tp-15  { background: #0d47a1; border-color: #42a5f5; color: #bbdefb; }
.tp-10  { background: #4a148c; border-color: #ab47bc; color: #e1bee7; }

/* ── Filter bar ── */
#fbar {
  position: sticky; top: 82px; z-index: 200;
  background: #fff; border-bottom: 2px solid #dde2e8;
  padding: 7px 18px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
}
#fbar label { font-size: 11px; font-weight: 600; color: #444; white-space: nowrap; }
#fbar select, #fbar input[type="text"] {
  padding: 4px 8px; border: 1px solid #ccc; border-radius: 4px; font-size: 11px; background: #fff;
}
#search { width: 170px; }
.btn { padding: 5px 12px; border: none; border-radius: 4px; cursor: pointer; font-size: 11px; font-weight: 600; white-space: nowrap; }
.btn-dark   { background: #0d1b2a; color: #fff; }
.btn-green  { background: #2e7d32; color: #fff; }
.btn-orange { background: #e65100; color: #fff; }
.btn-teal   { background: #00695c; color: #fff; }
.hint { font-size: 10px; color: #999; margin-left: auto; }

/* ── Table wrapper ── */
#wrap { overflow: auto; height: calc(100vh - 122px); }

table { width: 100%; border-collapse: collapse; min-width: 1560px; }

/* Section header rows inside thead */
thead tr.sh th {
  background: #37474f; color: #cfd8dc;
  font-size: 9px; font-weight: 700; text-transform: uppercase;
  letter-spacing: .5px; padding: 3px 6px;
  border-right: 1px solid #455a64;
}
thead tr.sh th.cy-hdr  { background: #1a237e; color: #c5cae9; }
thead tr.sh th.pr-hdr  { background: #212121; color: #bbb; }

thead tr.ch th {
  background: #1e2d3d; color: #d8e4f0;
  padding: 6px 6px; text-align: center;
  font-size: 10px; font-weight: 600; white-space: nowrap;
  border-right: 1px solid #2e4057;
  position: sticky; top: 0; z-index: 100;
}
thead tr.ch th.l { text-align: left; }

/* Cyber column section bg */
th.cy-col { background: #1a2a6e !important; }
td.cy-col { background: rgba(26,35,126,.04); }

/* Proj column section bg */
th.pr-col { background: #1a1a1a !important; }

tbody tr { border-bottom: 1px solid #e4e8ed; }
tbody tr:hover td { filter: brightness(.95); }

td { padding: 4px 5px; text-align: center; vertical-align: middle; white-space: nowrap; }
td.l { text-align: left; }
td.name { font-weight: 600; font-size: 11px; overflow: hidden; text-overflow: ellipsis; max-width: 200px; }
td.tipo { color: #666; font-size: 10px; text-transform: capitalize; }

/* Row tints by dominant activity */
tr.t40       { background: #fce4ec; }
tr.t30       { background: #fff1f1; }
tr.t20       { background: #fff8f0; }
tr.t15       { background: #f0f7ff; }
tr.t10       { background: #f6f1ff; }
tr.tsd       { background: #f8f8ff; }
tr.t0        { background: #fafafa; }

/* Badges */
.badge { display: inline-block; padding: 2px 7px; border-radius: 9px; font-size: 10px; font-weight: 700; }
.b-sd  { background: #c5cae9; color: #283593; }
.b-40  { background: #fce4ec; color: #880e4f; }
.b-30  { background: #ffcdd2; color: #b71c1c; }
.b-20  { background: #ffe0b2; color: #bf360c; }
.b-15  { background: #bbdefb; color: #0d47a1; }
.b-10  { background: #e1bee7; color: #4a148c; }
.b-0   { background: #eeeeee; color: #777; }

/* Inputs */
select.tsel {
  padding: 3px 4px; border: 1px solid #bbb; border-radius: 4px;
  font-size: 11px; width: 96px; cursor: pointer; background: #fff;
}
input.sti {
  width: 50px; padding: 3px 3px; border: 1px solid #bbb; border-radius: 4px;
  font-size: 11px; text-align: center; background: #fff;
}
input.sti:disabled { background: #f0f0f0; color: #aaa; cursor: not-allowed; }
input.sti:focus    { outline: none; border-color: #1976d2; }

/* Values */
.rev   { color: #1565c0; font-weight: 700; }
.mgn   { color: #2e7d32; font-weight: 700; }
.dash  { color: #ccc; }
.nocost { color: #bbb; font-size: 10px; }
.warn  { color: #e53935; font-weight: 700; }
.low   { color: #e53935; }
.mid   { color: #f57c00; }
.good  { color: #2e7d32; }
.small { font-size: 10px; color: #999; }

/* Group header */
tr.ghdr td {
  background: #2c3e50; color: #ecf0f1;
  font-size: 10px; font-weight: 700; padding: 4px 10px;
  letter-spacing: .3px; text-align: left;
}

/* Footer */
tfoot td {
  background: #0d1b2a; color: #fff;
  font-weight: 700; padding: 6px 5px;
  border-top: 2px solid #ffd700;
  font-size: 11px; text-align: center;
}
tfoot td.l { text-align: left; }
</style>
<script src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>
</head>
<body>

<!-- ── Summary Bar ── -->
<div id="bar">
  <div id="bar-top">
    <span class="brand">AS98 ✦ CYBER 2026</span>
    <div class="sep"></div>
    <div class="kpi"><span class="lbl">Revenue Total</span><span class="val green" id="s-rev">$0</span></div>
    <div class="kpi"><span class="lbl">Margen $</span><span class="val yellow" id="s-mgn">$0</span></div>
    <div class="kpi"><span class="lbl">Margen %</span><span class="val orange" id="s-mp">0%</span></div>
    <div class="kpi"><span class="lbl">Uds Totales</span><span class="val white" id="s-u">0</span></div>
    <div class="sep"></div>
    <div class="kpi"><span class="lbl">Objetivo</span><span class="val gray">$65.35M</span></div>
    <div class="kpi"><span class="lbl">Gap</span><span class="val red" id="s-gap">—</span></div>
    <div class="sep"></div>
    <div style="display:flex;flex-direction:column;gap:3px;justify-content:center;font-size:9.5px;color:#aab;line-height:1.4">
      <span>📦 Stock: <b style="color:#fff">26/05/2026</b></span>
      <span>📊 Ventas: <b style="color:#fff">25/05/2026 20:00</b></span>
      <span>✏️ Último dato: <b style="color:#ffd700" id="last-edit-ts">—</b></span>
    </div>
  </div>
  <div id="bar-bot">
    <span style="font-size:9px;color:#556;margin-right:10px;text-transform:uppercase;letter-spacing:.5px">Por etapa:</span>
    <span id="s-sd"  class="tier-pill tp-sd">Sin Dcto — $0 | 0u</span>
    <span id="s-40"  class="tier-pill tp-40">40% — $0 | 0u</span>
    <span id="s-30"  class="tier-pill tp-30">30%Liq — $0 | 0u</span>
    <span id="s-20"  class="tier-pill tp-20">20% — $0 | 0u</span>
    <span id="s-15"  class="tier-pill tp-15">15% — $0 | 0u</span>
    <span id="s-10"  class="tier-pill tp-10">10% — $0 | 0u</span>
  </div>
</div>

<!-- ── Filter bar ── -->
<div id="fbar">
  <label>Buscar:</label>
  <input type="text" id="search" placeholder="Nombre del producto..." oninput="applyFilters()">
  <label>Tipo:</label>
  <select id="ftipo" onchange="applyFilters()"><option value="">Todos</option></select>
  <label>Tier:</label>
  <select id="ftier" onchange="applyFilters()">
    <option value="">Todos</option>
    <option value="0">Sin asignar</option>
    <option value="sd">Sin Descuento</option>
    <option value="10">10%</option>
    <option value="15">15%</option>
    <option value="20">20%</option>
    <option value="30">30% Liq</option>
    <option value="40">40%</option>
  </select>
  <label>Stock mín:</label>
  <input type="text" id="fstock" placeholder="ej: 5" style="width:55px" oninput="applyFilters()">
  <button class="btn btn-orange" onclick="bulkST()">ST% masivo...</button>
  <button class="btn btn-dark"   onclick="clearAll()">Limpiar todo</button>
  <button class="btn btn-green"  onclick="exportCSV()">Exportar CSV</button>
  <button class="btn btn-orange" onclick="exportXLSXCombined()">Excel Descuentos</button>
  <span class="hint">
    Cyber = 29 Mayo–3 Jun, todos los clientes
  </span>
</div>

<!-- ── Table ── -->
<div id="wrap">
<table id="tbl">
<thead>
  <!-- Section labels -->
  <tr class="sh">
    <th colspan="12" style="text-align:left">PRODUCTO</th>
    <th colspan="3" class="cy-hdr" style="text-align:center">TIER CYBER — 29 Mayo al 3 Jun (Todos los clientes)</th>
    <th colspan="3" class="pr-hdr" style="text-align:center">PROYECCIÓN</th>
  </tr>
  <!-- Column labels -->
  <tr class="ch">
    <th class="l" style="min-width:195px">Producto</th>
    <th class="l" style="min-width:75px">Tipo</th>
    <th>Stock</th>
    <th title="Ventas en unidades últimos 60 días">Uds 60d</th>
    <th title="Ventas en unidades últimos 30 días">Uds 30d</th>
    <th title="Ventas en unidades últimos 15 días">Uds 15d</th>
    <th>Precio Púb.</th>
    <th>Precio Neto</th>
    <th>Costo Neto</th>
    <th>Margen%</th>
    <th>Max Dcto</th>
    <th>Uds '25</th>
    <th class="cy-col" style="min-width:100px">Tier</th>
    <th class="cy-col">ST% Cyber</th>
    <th class="cy-col">Uds Cyber</th>
    <th class="pr-col" style="min-width:105px">Rev. Cyber</th>
    <th class="pr-col" style="min-width:105px">Rev. Total</th>
    <th class="pr-col">Margen%</th>
  </tr>
</thead>
<tbody id="tbody"></tbody>
<tfoot>
  <tr>
    <td class="l" colspan="2" id="f-lbl">TOTAL VISIBLE</td>
    <td id="f-stk">—</td>
    <td colspan="9"></td>
    <td id="f-ucy">—</td>
    <td></td>
    <td id="f-ucy2">—</td>
    <td id="f-rcy">—</td>
    <td id="f-rt">—</td>
    <td id="f-mp">—</td>
  </tr>
</tfoot>
</table>
</div>

