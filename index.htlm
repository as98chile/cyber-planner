    localStorage.setItem(LS_KEY, JSON.stringify(snap));
    localStorage.setItem(LS_VER_KEY, PLAN_VER);
    localStorage.setItem(LS_TS_KEY, ts);
  } catch(e) {}
  document.getElementById('last-edit-ts').textContent = ts;
}
