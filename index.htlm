    snap[p.title] = { ea: p.ea, eaDcto: p.eaDcto, eaST: p.eaST, cyberTier: p.cyberTier, cyberST: p.cyberST };
  });
  var now = new Date();
  var ts = now.toLocaleDateString('es-CL') + ' ' + now.toLocaleTimeString('es-CL', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
