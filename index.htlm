    storedTs  = localStorage.getItem(LS_TS_KEY) || '';
  } catch(e) {}
  // If CSV version changed, ignore localStorage and use fresh CSV data
  if (!snap || storedVer !== PLAN_VER) return;
  arr.forEach(function(p) {
    var s = snap[p.title];
    if (!s) return;
    p.ea = s.ea; p.eaDcto = s.eaDcto; p.eaST = s.eaST;
    p.cyberTier = s.cyberTier; p.cyberST = s.cyberST;
  });
  if (storedTs) document.getElementById('last-edit-ts').textContent = storedTs;
}

// ─── State ────────────────────────────────────────────────────────────────────
const P = RAW.map(function(p, i) {
  return {
    id: i, title: p.title, tipo: p.tipo, stock: p.stock,
    precioPubl: p.precioPubl, precioNeto: p.precioNeto, costoNeto: p.costoNeto,
    margenPct: p.margenPct, maxDcto: p.maxDcto, uds25: p.uds25, uds60d: p.uds60d||0, uds30d: p.uds30d||0, uds15d: p.uds15d||0, isEA: p.isEA,
    ea: p.ea, eaDcto: p.eaDcto||0, eaST: p.eaST,
    cyberTier: p.cyberTier, cyberST: p.cyberST
  };
});
// Restore saved state on load (overrides CSV defaults)
loadLS(P);

// Populate tipo filter
var tipos = [];
P.forEach(function(p) { if (tipos.indexOf(p.tipo) < 0) tipos.push(p.tipo); });
tipos.sort();
var tipoEl = document.getElementById('ftipo');
tipos.forEach(function(t) {
  var o = document.createElement('option'); o.value = t; o.textContent = t;
  tipoEl.appendChild(o);
});

// ─── Helpers ─────────────────────────────────────────────────────────────────
function clp(n) { return n > 0 ? '$' + Math.round(n).toLocaleString('es-CL') : null; }
function mpCls(v) { return v === null ? '' : v >= 45 ? 'good' : v >= 35 ? 'mid' : 'low'; }
function dash(s) { return s || '<span class="dash">—</span>'; }
function tierDcto(t) {
  if (t === 'sd') return 0;
  var n = parseInt(t) || 0;
  return n / 100;
}

function calc(p) {
  var cyberU = (p.cyberTier && p.cyberST > 0)
    ? Math.floor(p.stock * p.cyberST / 100) : 0;
  var dcto   = p.cyberTier ? tierDcto(p.cyberTier) : 0;
  var cyberR = cyberU > 0 ? cyberU * p.precioNeto * (1 - dcto) : 0;

  var totM  = (cyberR > 0 && p.costoNeto > 0) ? cyberR - cyberU * p.costoNeto : null;
  var totMp = (totM !== null && cyberR > 0) ? totM / cyberR * 100 : null;

  return { cyberU: cyberU, cyberR: cyberR,
           totU: cyberU, totR: cyberR, totM: totM, totMp: totMp };
}

function rowClass(p) {
  if (!p.cyberTier) return 't0';
  if (p.cyberTier === 'sd') return 'tsd';
  if (p.cyberTier === 40) return 't40';
  if (p.cyberTier === 30) return 't30';
  if (p.cyberTier === 20) return 't20';
  if (p.cyberTier === 15) return 't15';
  if (p.cyberTier === 10) return 't10';
  return 't0';
}

function tierBadge(t) {
  if (!t) return '<span class="badge b-0">—</span>';
  if (t === 'sd')  return '<span class="badge b-sd">Sin Dcto</span>';
  if (t === 40)    return '<span class="badge b-40">40%</span>';
  if (t === 30)    return '<span class="badge b-30">30% Liq</span>';
  if (t === 20)    return '<span class="badge b-20">20%</span>';
  if (t === 15)    return '<span class="badge b-15">15%</span>';
  if (t === 10)    return '<span class="badge b-10">10%</span>';
  return '<span class="badge b-0">—</span>';
}

// ─── Render ───────────────────────────────────────────────────────────────────
var visibleIds = P.map(function(p){ return p.id; });

function renderTable() {
  var vis  = P.filter(function(p){ return visibleIds.indexOf(p.id) >= 0; });
  var html = '', lastTipo = null;

  vis.forEach(function(p) {
    if (p.tipo !== lastTipo) {
      var cnt = vis.filter(function(x){ return x.tipo === p.tipo; }).length;
      html += '<tr class="ghdr"><td colspan="18">&#9670; ' + p.tipo.toUpperCase() + ' &mdash; ' + cnt + ' productos</td></tr>';
      lastTipo = p.tipo;
    }

    var c  = calc(p);
    var rc = rowClass(p);

    // Margen actual
    var mgStr = p.margenPct !== null
      ? '<span class="' + mpCls(p.margenPct) + '">' + p.margenPct.toFixed(1) + '%</span>'
      : '<span class="nocost">S/C</span>';

    // Max dcto
    var cyberDctoNum = (p.cyberTier && p.cyberTier !== 'sd') ? parseInt(p.cyberTier) : 0;
    var overDcto = cyberDctoNum > 0 && p.costoNeto > 0 && cyberDctoNum > p.maxDcto;
    var mdStr = p.maxDcto > 0
      ? (overDcto ? '<span class="warn">&#9888;' + p.maxDcto.toFixed(1) + '%</span>' : p.maxDcto.toFixed(1) + '%')
      : '<span class="nocost">N/D</span>';

    // Projected values
    var cyRStr  = c.cyberR > 0 ? '<span class="rev">' + clp(c.cyberR) + '</span>' : '<span class="dash">—</span>';
    var totRStr = c.totR > 0 ? '<span class="rev" style="font-size:12px">' + clp(c.totR) + '</span>' : '<span class="dash">—</span>';
    var mpStr   = (c.totMp !== null && c.totR > 0)
      ? '<span class="' + mpCls(c.totMp) + '">' + c.totMp.toFixed(1) + '%</span>'
      : '<span class="dash">—</span>';

    var u25 = p.uds25 > 0 ? p.uds25 : '<span class="dash">—</span>';
    var cosStr = p.costoNeto > 0 ? clp(p.costoNeto) : '<span class="nocost">S/C</span>';

    // Cyber tier select options
    var ctOpts = [
      ['', '  —  '], ['sd', 'Sin Dcto'], ['10', '10%'],
      ['15', '15%'], ['20', '20%'], ['30', '30% Liq'], ['40', '40%']
    ].map(function(o) {
      var sel = (String(p.cyberTier) === o[0] || (p.cyberTier === 0 && o[0] === '')) ? ' selected' : '';
      return '<option value="' + o[0] + '"' + sel + '>' + o[1] + '</option>';
    }).join('');

    html += '<tr class="' + rc + '" data-id="' + p.id + '">'
      + '<td class="l name">' + p.title + '</td>'
      + '<td class="l tipo">' + p.tipo + '</td>'
      + '<td><b>' + p.stock + '</b></td>'
      + '<td>' + (p.uds60d > 0 ? '<span style="color:#1565c0;font-weight:600">' + p.uds60d + '</span>' : '<span class="dash">—</span>') + '</td>'
      + '<td>' + (p.uds30d > 0 ? '<span style="color:#1565c0;font-weight:600">' + p.uds30d + '</span>' : '<span class="dash">—</span>') + '</td>'
      + '<td>' + (p.uds15d > 0 ? '<span style="color:#1565c0;font-weight:600">' + p.uds15d + '</span>' : '<span class="dash">—</span>') + '</td>'
      + '<td>' + dash(clp(p.precioPubl)) + '</td>'
      + '<td>' + dash(clp(p.precioNeto)) + '</td>'
      + '<td>' + (p.costoNeto > 0 ? clp(p.costoNeto) : '<span class="nocost">S/C</span>') + '</td>'
      + '<td>' + mgStr + '</td>'
      + '<td>' + mdStr + '</td>'
      + '<td>' + u25  + '</td>'
      // Cyber columns
      + '<td class="cy-col"><select class="tsel" onchange="setCyberTier(' + p.id + ',this.value)">'
      +   ctOpts + '</select></td>'
      + '<td class="cy-col">'
      +   '<input class="sti" type="number" min="0" max="100" value="' + p.cyberST + '"'
      +   ' onchange="setCyberST(' + p.id + ',+this.value)">'
      + '</td>'
      + '<td class="cy-col">' + (c.cyberU > 0 ? c.cyberU : '<span class="dash">—</span>') + '</td>'
      // Projected
      + '<td>' + cyRStr  + '</td>'
      + '<td>' + totRStr + '</td>'
      + '<td>' + mpStr   + '</td>'
      + '</tr>';
  });

  document.getElementById('tbody').innerHTML = html;
  refreshTotals();
}

// ─── Refresh totals ───────────────────────────────────────────────────────────
function refreshTotals() {
  var totR=0,totM=0,totU=0;
  var byStage = { sd:{r:0,u:0}, 40:{r:0,u:0}, 30:{r:0,u:0}, 20:{r:0,u:0}, 15:{r:0,u:0}, 10:{r:0,u:0} };

  P.forEach(function(p) {
    var c = calc(p);
    totR += c.totR; totU += c.totU;
    if (c.totM !== null) totM += c.totM;
    if (p.cyberTier === 'sd' && c.cyberR > 0) { byStage.sd.r += c.cyberR; byStage.sd.u += c.cyberU; }
    if (p.cyberTier === 40 && c.cyberR > 0)   { byStage[40].r += c.cyberR; byStage[40].u += c.cyberU; }
    if (p.cyberTier === 30 && c.cyberR > 0)   { byStage[30].r += c.cyberR; byStage[30].u += c.cyberU; }
    if (p.cyberTier === 20 && c.cyberR > 0)   { byStage[20].r += c.cyberR; byStage[20].u += c.cyberU; }
    if (p.cyberTier === 15 && c.cyberR > 0)   { byStage[15].r += c.cyberR; byStage[15].u += c.cyberU; }
    if (p.cyberTier === 10 && c.cyberR > 0)   { byStage[10].r += c.cyberR; byStage[10].u += c.cyberU; }
  });
  var mp  = totR > 0 ? totM/totR*100 : 0;
  var gap = totR - OBJETIVO;

  document.getElementById('s-rev').textContent = '$' + (totR/1e6).toFixed(2) + 'M';
  document.getElementById('s-mgn').textContent = '$' + (totM/1e6).toFixed(2) + 'M';
  document.getElementById('s-mp').textContent  = mp.toFixed(1) + '%';
  document.getElementById('s-u').textContent   = totU.toLocaleString('es-CL');
  var gEl = document.getElementById('s-gap');
  if (gap >= 0) { gEl.textContent = '+$'+(gap/1e6).toFixed(2)+'M'; gEl.className='val green'; }
  else          { gEl.textContent = '−$'+(Math.abs(gap)/1e6).toFixed(2)+'M'; gEl.className='val red'; }

  function pill(id, r, u) {
    var el = document.getElementById(id);
    var base = el.textContent.split('—')[0] + '—';
    el.textContent = el.textContent.replace(/\$.*/, '') ;
    var parts = el.textContent.split('—');
    el.textContent = parts[0] + '— $' + (r/1e6).toFixed(2) + 'M | ' + u + 'u';
  }
  pill('s-sd', byStage.sd.r,   byStage.sd.u);
  pill('s-40', byStage[40].r,  byStage[40].u);
  pill('s-30', byStage[30].r,  byStage[30].u);
  pill('s-20', byStage[20].r,  byStage[20].u);
  pill('s-15', byStage[15].r,  byStage[15].u);
  pill('s-10', byStage[10].r,  byStage[10].u);

  // Footer (visible only)
  var vis = P.filter(function(p){ return visibleIds.indexOf(p.id) >= 0; });
  var vS=0,vCyU=0,vCyR=0,vTotR=0,vTotM=0;
  vis.forEach(function(p) {
    vS += p.stock;
    var c = calc(p);
    vCyU+=c.cyberU; vCyR+=c.cyberR;
    vTotR+=c.totR;
    if (c.totM!==null) vTotM+=c.totM;
  });
  var vMp = vTotR > 0 ? vTotM/vTotR*100 : 0;
  document.getElementById('f-lbl').textContent  = 'TOTAL (' + vis.length + ' productos)';
  document.getElementById('f-stk').textContent  = vS.toLocaleString('es-CL');
  document.getElementById('f-uea').textContent  = vEaU > 0 ? vEaU : '—';
  document.getElementById('f-ueac').textContent = vEaU > 0 ? vEaU : '—';
  document.getElementById('f-ucy').textContent  = vCyU > 0 ? vCyU : '—';
  document.getElementById('f-ucy2').textContent = vCyU > 0 ? vCyU : '—';
  document.getElementById('f-rea').textContent  = vEaR  > 0 ? '$'+Math.round(vEaR).toLocaleString('es-CL') : '—';
  document.getElementById('f-rcy').textContent  = vCyR  > 0 ? '$'+Math.round(vCyR).toLocaleString('es-CL') : '—';
  document.getElementById('f-rt').textContent   = vTotR > 0 ? '$'+Math.round(vTotR).toLocaleString('es-CL') : '—';
  document.getElementById('f-mp').textContent   = vMp > 0 ? vMp.toFixed(1)+'%' : '—';
}

// ─── Update single row ────────────────────────────────────────────────────────
function updateRow(id) {
  var p  = P[id];
  var c  = calc(p);
  var tr = document.querySelector('tr[data-id="' + id + '"]');
  if (!tr) { refreshTotals(); return; }

  tr.className = rowClass(p);

  // Tier select
  var sel = tr.querySelector('select.tsel');
  if (sel) sel.value = String(p.cyberTier || '');

  var tds = tr.querySelectorAll('td');
  // 0-11: producto cols, 12: Tier, 13: ST%Cyber, 14: UdsCyber, 15: RevCyber, 16: RevTotal, 17: Mrg%
  tds[14].innerHTML = c.cyberU > 0 ? c.cyberU : '<span class="dash">—</span>';
  tds[15].innerHTML = c.cyberR > 0 ? '<span class="rev">'+clp(c.cyberR)+'</span>' : '<span class="dash">—</span>';
  tds[16].innerHTML = c.totR   > 0 ? '<span class="rev" style="font-size:12px">'+clp(c.totR)+'</span>' : '<span class="dash">—</span>';
  tds[17].innerHTML = (c.totMp!==null && c.totR>0)
    ? '<span class="'+mpCls(c.totMp)+'">'+c.totMp.toFixed(1)+'%</span>'
    : '<span class="dash">—</span>';

  refreshTotals();
}

// ─── Event handlers ───────────────────────────────────────────────────────────
function setCyberTier(id, val) {
  var p = P[id];
  p.cyberTier = val === '' ? 0 : (val === 'sd' ? 'sd' : parseInt(val));
  if (p.cyberTier) {
    if (p.cyberST === 0) {
      if      (p.cyberTier === 40) p.cyberST = 50;
      else if (p.cyberTier === 30) p.cyberST = 40;
      else if (p.cyberTier === 20) p.cyberST = 15;
      else if (p.cyberTier === 15) p.cyberST = 12;
      else if (p.cyberTier === 10 || p.cyberTier === 'sd') p.cyberST = 10;
    }
  } else {
    p.cyberST = 0;
  }
  saveLS();
  setTimeout(function(){ updateRow(id); }, 0);
}
function setCyberST(id, val) {
  P[id].cyberST = Math.min(100, Math.max(0, val||0));
  saveLS();
  setTimeout(function(){ updateRow(id); }, 0);
}
function setEADcto(id, val) {
  var p = P[id];
  var newDcto = val === '' ? 0 : (val === 'sd' ? 0 : parseInt(val));
  var cyberDcto = (!p.cyberTier || p.cyberTier === 'sd') ? 0 : (parseInt(p.cyberTier) || 0);
  // EA discount must be >= Cyber tier discount
  if (cyberDcto > 0 && newDcto < cyberDcto) {
    p.eaDcto = p.cyberTier;
  } else {
    p.eaDcto = val === '' ? 0 : (val === 'sd' ? 'sd' : parseInt(val));
  }
  saveLS();
  setTimeout(function(){ updateRow(id); }, 0);
}

// ─── Filters ─────────────────────────────────────────────────────────────────
function applyFilters() {
  var s  = document.getElementById('search').value.toLowerCase();
  var ft = document.getElementById('ftipo').value;
  var fi = document.getElementById('ftier').value;
  var fs = parseInt(document.getElementById('fstock').value) || 0;
  visibleIds = P.filter(function(p) {
    var matchTier = !fi
      || (fi === '0'  && !p.cyberTier)
      || (fi === 'sd' && p.cyberTier === 'sd')
      || (fi === '10' && p.cyberTier === 10)
      || (fi === '15' && p.cyberTier === 15)
      || (fi === '20' && p.cyberTier === 20)
      || (fi === '30' && p.cyberTier === 30)
      || (fi === '40' && p.cyberTier === 40);
    return (!s  || p.title.toLowerCase().indexOf(s) >= 0)
        && (!ft || p.tipo === ft)
        && matchTier
        && (p.stock >= fs);
  }).map(function(p){ return p.id; });
  renderTable();
}

// ─── Bulk actions ─────────────────────────────────────────────────────────────
function bulkST() {
  var tier = prompt('Tier a modificar (sd, 10, 15, 20, 30, 40):');
  if (!tier) return;
  var st = prompt('Sell-through % para tier "' + tier + '":');
  if (st === null) return;
  var stVal = Math.min(100, Math.max(0, parseFloat(st)||0));
  P.forEach(function(p) {
    if (tier === 'sd' && p.cyberTier === 'sd') p.cyberST = stVal;
    else if (parseInt(tier) === p.cyberTier)   p.cyberST = stVal;
  });
  saveLS(); renderTable();
}
function clearAll() {
  if (!confirm('Limpiar TODOS los tiers y sell-throughs?')) return;
  P.forEach(function(p) { p.cyberTier=0; p.cyberST=0; });
  try { localStorage.removeItem(LS_KEY); } catch(e) {}
  renderTable();
}

// ─── Export CSV ───────────────────────────────────────────────────────────────
function exportCSV() {
  var lines = ['Producto,Tipo,Stock,Uds60d,Uds30d,Uds15d,PrecioPublico,PrecioNeto,CostoNeto,Margen%,MaxDcto,Uds2025,'
    + 'TierCyber,ST_Cyber%,UdsCyber,RevCyber,'
    + 'RevTotal,MargenTotal,MargenTotal%'];
  P.forEach(function(p) {
    var c = calc(p);
    lines.push([
      '"'+p.title+'"', '"'+p.tipo+'"', p.stock, p.uds60d, p.uds30d, p.uds15d, p.precioPubl, p.precioNeto, p.costoNeto,
      p.margenPct!==null?p.margenPct:'', p.maxDcto, p.uds25,
      p.cyberTier||'', p.cyberST, c.cyberU, Math.round(c.cyberR),
      Math.round(c.totR),
      c.totM!==null?Math.round(c.totM):'',
      c.totMp!==null?c.totMp.toFixed(1):''
    ].join(','));
  });
  var blob = new Blob(['﻿'+lines.join('\n')], {type:'text/csv;charset=utf-8;'});
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob); a.download = 'cyber_2026_plan.csv'; a.click();
}

// ─── Export XLSX ─────────────────────────────────────────────────────────────
function exportXLSXCombined() {
  var rows = P.filter(function(p) {
    return p.cyberTier && (p.cyberTier === 'sd' || typeof p.cyberTier === 'number');
  });
  if (!rows.length) { alert('No hay productos con Tier asignado.'); return; }
  var wsData = [
    ['Descuentos Cyber — 29 Mayo al 3 Jun 2026'],
    [],
    ['Producto', 'SKU', 'Tipo', 'Precio Público', 'Descuento %', 'Precio con Descuento']
  ];
  rows.forEach(function(p) {
    var dcto       = (p.cyberTier === 'sd' || !p.cyberTier) ? 0 : p.cyberTier;
    var precioDcto = Math.floor(p.precioPubl * (1 - dcto / 100) / 10) * 10;
    wsData.push([p.title, p.skus || '', p.tipo, p.precioPubl, dcto / 100, precioDcto]);
  });
  var ws = XLSX.utils.aoa_to_sheet(wsData);
  ws['!cols']   = [{ wch: 45 }, { wch: 30 }, { wch: 14 }, { wch: 14 }, { wch: 12 }, { wch: 18 }];
  ws['!merges'] = [{ s: { r: 0, c: 0 }, e: { r: 0, c: 5 } }];
  var range = XLSX.utils.decode_range(ws['!ref']);
  for (var r = 3; r <= range.e.r; r++) {
    var cD = XLSX.utils.encode_cell({ r: r, c: 3 });
    var cE = XLSX.utils.encode_cell({ r: r, c: 4 });
    var cF = XLSX.utils.encode_cell({ r: r, c: 5 });
    if (ws[cD]) ws[cD].z = '#,##0';
    if (ws[cE]) ws[cE].z = '0%';
    if (ws[cF]) ws[cF].z = '#,##0';
  }
  var wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Cyber 29 Mayo');
  XLSX.writeFile(wb, 'Descuentos_Cyber2026.xlsx');
}

// ─── Init ─────────────────────────────────────────────────────────────────────
renderTable();
</script>
</body>
</html>
